{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": [
    {
      "target": "lab",
      "public": "dist-web",
      "ignore": ["firebase.json", "**/.*"],
      "headers": [
        {
          "source": "**/*.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "**/*.@(png|webmanifest)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
        }
      ]
    },
    {
      "target": "clinic",
      "public": "dist-clinic",
      "ignore": ["firebase.json", "**/.*"],
      "headers": [
        {
          "source": "**/*.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "**/*.@(png|webmanifest)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
        }
      ]
    }
  ]
}
