{
  "appId": "com.laboratorio.specialclinic",
  "appName": "Special Clinic",
  "webDir": "www",
  "plugins": {
    "FirebaseAuthentication": {
      "skipNativeAuth": false,
      "providers": [
        "google.com",
        "apple.com"
      ]
    },
    "PushNotifications": {
      "presentationOptions": [
        "badge",
